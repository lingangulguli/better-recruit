.hero {
  padding: 48rpx 0 40rpx;
}
.hero-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #0F121A;
  line-height: 1.25;
  letter-spacing: -0.5rpx;
}
.hero-subtitle {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #5F6A7D;
  line-height: 1.6;
}

.section-title {
  margin: 24rpx 0 20rpx;
  font-size: 22rpx;
  color: #8B95A8;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  font-weight: 500;
}

.scene-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.scene-item {
  background: #FFFFFF;
  border: 1rpx solid #EEF0F4;
  border-radius: 16rpx;
  padding: 32rpx;
}
.scene-item:active {
  border-color: #B8BFCC;
}
.scene-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #0F121A;
}
.scene-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8B95A8;
}
.scene-desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #5F6A7D;
  line-height: 1.5;
}

.notice {
  margin-top: 48rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border: 1rpx dashed #DCE0E8;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #8B95A8;
  line-height: 1.6;
}
